{
  "name": "yt-downloader",
  "version": "1.0.0",
  "description": "Personal YouTube and Instagram downloader (CLI + Telegram bot)",
  "keywords": [
    "youtube",
    "instagram",
    "downloader",
    "telegram",
    "yt-dlp"
  ],
  "bin": {
    "yt-dl": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "nodemon",
    "deploy": "npm run build && pm2 startOrReload ecosystem.config.cjs --update-env",
    "download": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "bot:start": "node dist/bot.js",
    "cleanup:downloads": "tsx src/cleanup-downloads-cli.ts",
    "cleanup:downloads:prod": "node dist/cleanup-downloads-cli.js"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "UNLICENSED",
  "private": true,
  "devDependencies": {
    "@types/node": "^26.1.0",
    "nodemon": "^3.1.14",
    "pm2": "^7.0.3",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "axios": "^1.18.1",
    "dotenv": "^17.4.2",
    "form-data": "^4.0.6",
    "telegraf": "^4.16.3",
    "yt-dlp-wrap-plus": "^2.4.3"
  }
}
