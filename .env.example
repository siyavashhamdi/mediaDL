# Media downloader (YouTube & Instagram) — Telegram bot
# Get your token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Optional: where downloaded files are stored before sending
DOWNLOAD_DIR=./downloads

# Who can use the bot (re-read on every request — edit while the bot is running)
# ACCESS_LIST_FILE=./users.json

# Daily log files (one file per day: logs/YYYY-MM-DD.log)
# LOG_DIR=./logs

# Optional: auto-cleanup while the bot is running (defaults: 1 hour)
# DOWNLOAD_CLEANUP_MAX_AGE_MS=3600000
# DOWNLOAD_CLEANUP_INTERVAL_MS=3600000
